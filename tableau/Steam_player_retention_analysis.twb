                  <format attr='border-style' value='none' />
                  <format attr='border-width' value='0' />
                  <format attr='margin' value='4' />
                </zone-style>
              </zone>
            </zone>
            <zone h='11161' id='18' type-v2='text' w='49210' x='781' y='12203'>
              <formatted-text>
                <run fontcolor='#000000' fontname='Benton Sans Book' lmargin='600' rmargin='600'>Month Index is reversed chronologically: </run>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' lmargin='600' rmargin='600'>1 = most recent month</run>
                <run fontcolor='#000000' fontname='Benton Sans Book' lmargin='600' rmargin='600'>, </run>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' lmargin='600' rmargin='600'>12 = earliest month in the dataset. </run>
                <run fontcolor='#000000' fontname='Benton Sans Book' lmargin='600' rmargin='600'>Note: the most recent month for this data is February.</run>
              </formatted-text>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='4' />
              </zone-style>
            </zone>
            <zone h='11161' id='30' type-v2='text' w='49210' x='781' y='1042'>
              <formatted-text>
                <run fontcolor='#000000' fontname='Benton Sans Book'>This analysis includes Steam games with at least </run>
                <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>12 months of available player data</run>
                <run fontcolor='#000000' fontname='Benton Sans Book'>, ensuring that lifecycle patterns are observed across a full year of activity. Games with shorter histories were excluded to maintain consistent comparisons across time.</run>
              </formatted-text>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='4' />
              </zone-style>
            </zone>
          </zone>
          <zone h='69585' id='7' param='horz' type-v2='layout-flow' w='49228' x='49991' y='23416'>
            <zone h='69585' id='12' name='Player count 1m vs 6m' w='49228' x='49991' y='23416'>
              <layout-cache minwidth='166' type-h='fixed' type-w='scalable' />
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='4' />
              </zone-style>
            </zone>
          </zone>
          <zone h='11957' id='9' param='horz' type-v2='layout-flow' w='49228' x='49991' y='1042'>
            <zone h='11957' id='19' type-v2='text' w='49228' x='49991' y='1042'>
              <formatted-text>
                <run fontcolor='#000000' fontname='Benton Sans Book'>While overall player activity remains relatively stable, several spikes appear in the data. These may coincide with major Steam sales events, which are known to temporarily increase player engagement across many titles.</run>
              </formatted-text>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='4' />
              </zone-style>
            </zone>
          </zone>
          <zone h='10417' id='20' type-v2='text' w='49228' x='49991' y='12999'>
            <formatted-text>
              <run fontcolor='#000000' fontname='Benton Sans Book'>Most games cluster near the lower player ranges, reflecting the highly skewed distribution of the Steam market where a small number of titles attract very large audiences while the majority operate at smaller scales.</run>
            </formatted-text>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
