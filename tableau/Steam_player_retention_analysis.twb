    <dashboard enable-sort-zone-taborder='true' name='Retention Rankings'>
      <style>
        <style-rule element='table'>
          <format attr='background-color' value='#ddebf0' />
        </style-rule>
      </style>
      <size maxheight='768' maxwidth='1024' minheight='768' minwidth='1024' preset-index='2' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='6' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='63281' id='5' param='horz' type-v2='layout-flow' w='30379' x='781' y='29728'>
            <zone h='63281' id='10' name='Top 10 Category' w='30379' x='781' y='29728'>
              <layout-cache minwidth='240' type-h='fixed' type-w='scalable' />
              <zone-style>
