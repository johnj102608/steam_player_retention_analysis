            <zone h='63281' id='12' name='Top 10 Genre' w='37299' x='31160' y='29728'>
              <layout-cache minwidth='240' type-h='fixed' type-w='scalable' />
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
